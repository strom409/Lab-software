@using EasioCore.Models
@{
    ViewData["Title"] = "Today's Collection";
    Layout = "~/Views/Shared/_RegistrationLayout.cshtml";
    var dateFrom = ViewBag.DateFrom as string ?? "";
    var dateTo = ViewBag.DateTo as string ?? "";
    var forUser = ViewBag.ForUser as string ?? "";
    var receipts = ViewBag.Receipts as List<DupReceipt> ?? new List<DupReceipt>();
    var total = ViewBag.Total as decimal? ?? 0;
    var totalCash = ViewBag.TotalCash as decimal? ?? 0;
    var totalTransfer = ViewBag.TotalTransfer as decimal? ?? 0;
    var companyName = ViewBag.CompanyName as string ?? "Easio Lab Software";
}
<div class="card card-outline card-info shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="card-title mb-0">Today - Receipt Report</h5>
        <div>
            <a asp-action="Index" class="btn btn-danger btn-sm"><i class="fas fa-backward"></i> Back</a>
        </div>
    </div>
    <div class="card-body">
        <form method="get" asp-action="TodaysCollection" class="mb-4">
            <fieldset class="border rounded p-3">
                <legend class="w-auto" style="font-size: 1rem;">Search Receipts</legend>
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small">Date From</label>
                        <input type="text" name="dateFrom" class="form-control form-control-sm" placeholder="dd-MM-yyyy" value="@dateFrom" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">Date To</label>
                        <input type="text" name="dateTo" class="form-control form-control-sm" placeholder="dd-MM-yyyy" value="@dateTo" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-success btn-sm w-100">Generate</button>
                    </div>
                </div>
            </fieldset>
        </form>

        @if (receipts.Count > 0)
        {
            <div class="row justify-content-center mb-3">
                <div class="col-auto text-center">
                    <h5 class="fw-bold">@companyName</h5>
                    <p class="mb-0">(Cash Collection Statement of User: <strong>@forUser</strong>)</p>
                    <p class="mb-0">Date: <strong>@dateFrom</strong> to <strong>@dateTo</strong></p>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-sm">
                    <thead class="table-dark">
                        <tr>
                            <th>S No.</th>
                            <th>Receipt No</th>
                            <th>Receipt Date</th>
                            <th>Patient Name</th>
                            <th>Mode</th>
                            <th class="text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < receipts.Count; i++)
                        {
                            var r = receipts[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@r.ReceiptNo</td>
                                <td>@r.ReceiptDate</td>
                                <td>@r.PName</td>
                                <td>@r.ReceiptMode</td>
                                <td class="text-end">@r.Amt</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-dark">
                        <tr>
                            <td colspan="5" class="text-end">Total:</td>
                            <td class="text-end">@total.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="mt-2">
                <strong>Cash Amount Rs. @totalCash.ToString("N2")</strong><br />
                <strong>Transfer Amount Rs. @totalTransfer.ToString("N2")</strong>
            </div>
        }
        else
        {
            <p class="text-muted">No data found for the selected date range.</p>
        }
    </div>
</div>
