<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Easio Lab Software</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        .main-header { background: #fff; border-bottom: 1px solid #dee2e6; }
        .nav-reg { font-size: 22px; font-weight: 500; color: #6c757d; }
        .btn-dup { background-color: #00bcd4; color: #fff !important; border-radius: 5px; padding: 6px 12px; }
        .btn-dup:hover { color: #fff; opacity: 0.9; }
        .btn-today { background-color: #ed930b; color: #fff !important; border-radius: 5px; padding: 6px 12px; }
        .btn-today:hover { color: #fff; opacity: 0.9; }
        .fyear-badge { padding: 6px 12px; color: #333; }
        .reg-footer { margin-left: 0; padding: 10px 15px; font-size: 14px; }
    </style>
</head>
<body>
    <nav class="main-header navbar navbar-expand navbar-white navbar-light">
        <ul class="navbar-nav">
            <li class="nav-item">
                <span class="nav-reg nav-link">Easio Lab Software</span>
            </li>
        </ul>
        <ul class="navbar-nav ms-auto">
            <li class="nav-item me-2">
                <a asp-controller="Registration" asp-action="DuplicateReceipt" class="btn-dup nav-link">Duplicate Receipt</a>
            </li>
            <li class="nav-item me-2">
                <a asp-controller="Registration" asp-action="TodaysCollection" class="btn-today nav-link">Today's Collection: ₹@(ViewBag.TodaysCollection ?? "0.00")</a>
            </li>
            <li class="nav-item me-2">
                <span class="fyear-badge nav-link">FYear: @(ViewBag.FYear ?? "2025-26")</span>
            </li>
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" style="color:#00bcd4!important">@(ViewBag.UserFullName ?? "User")</a>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" asp-controller="Auth" asp-action="Logout">Sign out</a></li>
                </ul>
            </li>
        </ul>
    </nav>
    <div class="content-wrapper" style="margin-top: 56px; min-height: calc(100vh - 56px);">
        <main class="p-3">
            @RenderBody()
        </main>
        <footer class="border-top reg-footer">
            <strong>Copyright &copy; 2011-2020 <a href="https://nationalitsolutions.com/">National IT Solutions</a>.</strong> All rights reserved.
            <div class="float-end d-none d-sm-inline-block"><b>Version</b> 3.1.0</div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
