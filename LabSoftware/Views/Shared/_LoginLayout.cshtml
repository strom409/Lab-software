<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LabSoftware</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background: #f4f6f9; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { max-width: 400px; }
        .login-logo { text-align: center; margin-bottom: 1.5rem; }
        .login-logo .company-name { font-size: 1.5rem; font-weight: 600; color: #333; text-decoration: none; }
        .input-group-text { background: #fff; border-right: 0; }
        .input-group .form-control { border-left: 0; }
        .input-group .form-control:focus { box-shadow: none; border-color: #ced4da; }
        .input-group:focus-within .input-group-text { border-color: #86b7fe; }
        .powered-by { background: linear-gradient(135deg, #1e3a5f 0%, #2c5282 100%); color: #fff; padding: 0.75rem; border-radius: 0 0 0.375rem 0.375rem; text-align: center; }
        .powered-by a { color: #93c5fd; text-decoration: none; }
        .powered-by a:hover { color: #bfdbfe; }
    </style>
</head>
<body>
    <div class="login-card w-100 px-3">
        @RenderBody()
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
